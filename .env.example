# Bookmarks example environment

APP_NAME="Bookmarks"
APP_ENV="production"
APP_BASE_URL="http://localhost:8010"

# Storage
BOOKMARKS_ROOT="/srv/webdata/bookmarks"
BOOKMARKS_DB_PATH="/srv/webdata/bookmarks/data/bookmarks.sqlite"
BOOKMARKS_MEDIA_ROOT="/srv/webdata/bookmarks/media"
BOOKMARKS_LOG_DIR="/srv/webdata/bookmarks/logs"

# ReClip
# Use host.docker.internal when Bookmarks runs in Docker.
RECLIP_BASE_URL="http://host.docker.internal:8899"
RECLIP_DEFAULT_FORMAT_ID="18"
RECLIP_POLL_INTERVAL_SECONDS="2"
RECLIP_DOWNLOAD_TIMEOUT_SECONDS="900"

# Auth
BOOKMARKS_USERNAME="admin"
# Store a hashed password in production, not a cleartext password.
# Argon2 hashes contain "$", so wrap real hashes in single quotes in .env.
BOOKMARKS_PASSWORD_HASH="CHANGE_ME"

# API token used by the browser extension.
BOOKMARKS_API_TOKEN="CHANGE_ME_LONG_RANDOM_TOKEN"

# Session security
SESSION_SECRET_KEY="CHANGE_ME_LONG_RANDOM_SECRET"
SESSION_COOKIE_NAME="bookmarks_session"
SESSION_COOKIE_SECURE="true"
SESSION_COOKIE_SAMESITE="lax"

# Server
HOST="0.0.0.0"
PORT="8000"
BOOKMARKS_HOST_PORT="8010"
LOG_LEVEL="info"
